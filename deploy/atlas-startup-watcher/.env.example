# atlas-startup-watcher — environment template.
#
# Copy to `.env` in the same directory and fill in real values BEFORE
# `docker compose up -d`. `.env` is gitignored; this `.env.example` is
# committed and contains NO real secrets.
#
# Required values come from the operator's Discord bot setup. If you
# already have a personal-ai project at ~/Development/personal-ai/ that
# uses the same Discord bot convention, source the two REQUIRED values
# from there:
#
#     grep -E '^(DISCORD_BOT_TOKEN|DISCORD_INFRA_CHANNEL_ID)=' \
#         ~/Development/personal-ai/.env \
#       | sed -E 's/[[:space:]]*#.*//; s/[[:space:]]+$//'
#
# Note: personal-ai's .env uses inline `# comments` after values, so
# strip them before pasting here (the sed pipeline above does that).

# ============================================================
# REQUIRED — the watcher refuses to start until these are set.
# ============================================================

# Discord bot token. Used as the `Authorization: Bot <token>` header
# when POSTing to https://discord.com/api/v10/channels/{channel}/messages.
# Create one at https://discord.com/developers/applications → New
# Application → Bot → Reset Token.
DISCORD_BOT_TOKEN=

# Discord channel ID (snowflake; 18-19 digits) where startup credentials
# get posted. Right-click the channel in Discord → Copy Channel ID
# (Developer Mode must be enabled in Discord settings → Advanced).
# Per personal-ai convention, this is the "infra health" channel.
DISCORD_INFRA_CHANNEL_ID=

# ============================================================
# OPTIONAL — sensible defaults; override only if your atlas
# deployment uses non-default container names or host ports.
# ============================================================

# LAN host that serves the atlas web UI. Used to build the clickable
# "Web UI" link in each Discord message. Default: 192.168.1.246.
ATLAS_HOST=192.168.1.246

# Host port the atlas web container is published on. Default: 3015
# (matches `deploy/observability/` and the canonical self-host bundle).
ATLAS_WEB_PORT=3015

# Docker container name of the atlas server. The watcher uses this for
# both `docker events --filter container=$ATLAS_CONTAINER` and
# `docker logs $ATLAS_CONTAINER`. Default matches the canonical
# self-host bundle's compose project name.
ATLAS_CONTAINER=security-atlas-atlas
