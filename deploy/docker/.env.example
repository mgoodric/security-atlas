# security-atlas — docker-compose self-host environment template (slice 037).
#
# Copy this file to `.env` in the same directory and edit every CHANGE_ME value
# BEFORE the first `docker compose up`. `.env` is gitignored;
# `.env.example` (this file) is committed and contains NO real secrets —
# every value here is the literal placeholder CHANGE_ME.
#
#   cp deploy/docker/.env.example deploy/docker/.env
#   ${EDITOR:-vi} deploy/docker/.env
#   docker compose -f deploy/docker/docker-compose.yml --env-file deploy/docker/.env up -d
#
# Generate strong random values for every *_PASSWORD / *_KEY / *_TOKEN:
#   openssl rand -hex 32
#
# ============================================================
# REQUIRED — the stack refuses to start until these are set.
# ============================================================

# Postgres superuser password. Used by the postgres container only.
POSTGRES_PASSWORD=CHANGE_ME

# Application role (atlas_app) password. The atlas server connects with
# this; the bootstrap container sets it on the role via ALTER ROLE.
# Must match between the atlas and atlas-bootstrap services (compose
# wires both from this single value).
ATLAS_APP_PASSWORD=CHANGE_ME

# MinIO root credentials. Double as the S3 access key / secret the atlas
# server uses to read+write the artifacts bucket.
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# HMAC key for api_keys.token_hash (slice 034). The atlas server
# refuses to boot without it. MUST be a high-entropy random value —
# `openssl rand -hex 32`. Rotating it invalidates every issued API key.
BEARER_HASH_KEY=CHANGE_ME

# Pre-shared admin bearer token (slice 037). The one-shot atlas-bootstrap
# container authenticates control-bundle uploads with this. It is a
# bootstrap convenience credential — ROTATE OR REVOKE IT after first
# boot via the admin UI / `atlas-cli credentials` once your real
# operator credential exists. `openssl rand -hex 32`.
ATLAS_BOOTSTRAP_TOKEN=CHANGE_ME

# Default local-mode user. This is the account you sign in with at the
# web UI on first boot (no external IdP required — AC-3). Change the
# password immediately after first sign-in.
ATLAS_DEFAULT_USER_EMAIL=admin@example.com
ATLAS_DEFAULT_USER_PASSWORD=CHANGE_ME

# Postgres connection strings the atlas server + bootstrap container use.
# Assembled here (not inline in docker-compose.yml) so the committed
# compose file never contains a `user:pass@host` literal. Replace the
# CHANGE_ME password segment in DATABASE_URL_APP with the same value you
# set for ATLAS_APP_PASSWORD above. DATABASE_URL_MIGRATE uses the
# atlas_migrate role, which authenticates via trust on the container
# network and carries no password. Host is the compose service name
# `postgres`; keep it unless you point at an external database.
DATABASE_URL_APP=postgres://atlas_app:CHANGE_ME@postgres:5432/security_atlas?sslmode=disable
DATABASE_URL_MIGRATE=postgres://atlas_migrate@postgres:5432/security_atlas?sslmode=disable

# ============================================================
# OPTIONAL — sensible defaults; override only if you need to.
# ============================================================

# Postgres database name.
POSTGRES_DB=security_atlas

# Default tenant UUID. The solo operator is a single-tenant deployment of
# the multi-tenant system (open question #13 resolved: multi-tenant from
# day one). Leave this default unless you are migrating data.
ATLAS_BOOTSTRAP_TENANT=00000000-0000-4000-8000-000000000001

# S3 bucket name for evidence artifacts > 1 MB (slice 036).
ARTIFACTS_BUCKET=atlas-artifacts

# AWS region label sent to the S3 client. MinIO ignores it; any value works.
AWS_REGION=us-east-1

# Set to "true" once the deployment is behind TLS so session cookies are
# Secure-flagged. The local-HTTP default is "false" (a Secure cookie over
# plain HTTP is silently dropped by browsers).
ATLAS_SECURE_COOKIES=false

# The API base URL the BROWSER uses to reach the atlas HTTP API. It must
# be reachable from the end user's machine.
#
# Leave EMPTY (the default) when this deployment is behind a reverse
# proxy that fronts both `web` and `atlas` under one hostname with
# path-based routing for /v1, /health, /api — the browser will use
# same-origin relative URLs and the proxy will route them to atlas.
#
# Set to an absolute URL only when the browser must reach atlas at a
# different origin than the web frontend (e.g. dev with web on :3000
# and atlas on :8080: NEXT_PUBLIC_API_BASE_URL=http://localhost:8080).
NEXT_PUBLIC_API_BASE_URL=

# ----- Host port mappings (change only on port conflicts) -----
POSTGRES_PORT=5432
NATS_PORT=4222
NATS_MONITOR_PORT=8222
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
ATLAS_HTTP_PORT=8080
ATLAS_GRPC_PORT=50051
WEB_PORT=3000
