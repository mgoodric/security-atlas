# security-atlas — docker-compose self-host environment template (slice 037).
#
# Copy this file to `.env` in the same directory and edit every CHANGE_ME value
# BEFORE the first `docker compose up`. `.env` is gitignored;
# `.env.example` (this file) is committed and contains NO real secrets —
# every value here is the literal placeholder CHANGE_ME.
#
#   cp deploy/docker/.env.example deploy/docker/.env
#   ${EDITOR:-vi} deploy/docker/.env
#   docker compose -f deploy/docker/docker-compose.yml --env-file deploy/docker/.env up -d
#
# Generate strong random values for every *_PASSWORD / *_KEY / *_TOKEN:
#   openssl rand -hex 32
#
# ============================================================
# REQUIRED — the stack refuses to start until these are set.
# ============================================================

# Postgres superuser password. Used by the postgres container only.
POSTGRES_PASSWORD=CHANGE_ME

# Application role (atlas_app) password. The atlas server connects with
# this; the bootstrap container sets it on the role via ALTER ROLE.
# Must match between the atlas and atlas-bootstrap services (compose
# wires both from this single value).
ATLAS_APP_PASSWORD=CHANGE_ME

# MinIO root credentials. Double as the S3 access key / secret the atlas
# server uses to read+write the artifacts bucket.
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# HMAC key for api_keys.token_hash (slice 034). The atlas server
# refuses to boot without it. MUST be a high-entropy random value —
# `openssl rand -hex 32`. Rotating it invalidates every issued API key.
BEARER_HASH_KEY=CHANGE_ME

# Pre-shared admin bearer token (slice 037). The one-shot atlas-bootstrap
# container authenticates control-bundle uploads with this. It is a
# bootstrap convenience credential — ROTATE OR REVOKE IT after first
# boot via the admin UI / `atlas-cli credentials` once your real
# operator credential exists. `openssl rand -hex 32`.
ATLAS_BOOTSTRAP_TOKEN=CHANGE_ME

# Default local-mode user. This is the account you sign in with at the
# web UI on first boot (no external IdP required — AC-3). Change the
# password immediately after first sign-in.
ATLAS_DEFAULT_USER_EMAIL=admin@example.com
ATLAS_DEFAULT_USER_PASSWORD=CHANGE_ME

# Postgres connection strings the atlas server + bootstrap container use.
# Assembled here (not inline in docker-compose.yml) so the committed
# compose file never contains a `user:pass@host` literal. Replace the
# CHANGE_ME password segment in DATABASE_URL_APP with the same value you
# set for ATLAS_APP_PASSWORD above. DATABASE_URL_MIGRATE uses the
# atlas_migrate role, which authenticates via trust on the container
# network and carries no password. Host is the compose service name
# `postgres`; keep it unless you point at an external database.
DATABASE_URL_APP=postgres://atlas_app:CHANGE_ME@postgres:5432/security_atlas?sslmode=disable
DATABASE_URL_MIGRATE=postgres://atlas_migrate@postgres:5432/security_atlas?sslmode=disable

# ============================================================
# OPTIONAL — sensible defaults; override only if you need to.
# ============================================================

# Postgres database name.
POSTGRES_DB=security_atlas

# Default tenant UUID. The solo operator is a single-tenant deployment of
# the multi-tenant system (open question #13 resolved: multi-tenant from
# day one). Leave this default unless you are migrating data.
ATLAS_BOOTSTRAP_TENANT=00000000-0000-4000-8000-000000000001

# Evidence-ingest substrate (slice 015). NATS JetStream URL the atlas
# server publishes evidence to. Leave commented to use the bundled `nats`
# service at its fixed compose-network address (the default below); the
# compose file falls back to exactly this value when the variable is
# unset, so the shipped bundle behaves identically whether or not you set
# it. Uncomment and override ONLY to point at an EXTERNAL NATS cluster
# (e.g. a shared JetStream deployment): NATS_URL=nats://nats.internal:4222
#
# When NATS_URL resolves to empty the server runs in dev mode — evidence
# push goes in-process with no durable buffer (slice 015). The bundle
# never does this; the default keeps the durable substrate wired.
# NATS_URL=nats://nats:4222

# S3 bucket name for evidence artifacts > 1 MB (slice 036).
ARTIFACTS_BUCKET=atlas-artifacts

# OAuth token-endpoint rate limit, per client_id, per minute (slice 187).
# The bundle's bootstrap container acquires up to 100 tokens per minute on
# an idempotent re-run (50 control bundles x first run + re-run), so the
# default is raised well above the 60/min library default to give the
# self-host bring-up headroom. The envelope is per-client_id, so other
# OAuth clients are unaffected. Override only to tighten or loosen the
# token-issuance budget for your deployment.
ATLAS_OAUTH_TOKEN_RATE_PER_MIN=600

# AWS region label sent to the S3 client. MinIO ignores it; any value works.
AWS_REGION=us-east-1

# Set to "true" once the deployment is behind TLS so session cookies are
# Secure-flagged. The local-HTTP default is "false" (a Secure cookie over
# plain HTTP is silently dropped by browsers).
ATLAS_SECURE_COOKIES=false

# Trusted reverse-proxy allowlist for client-IP capture on session rows and
# for the admin-demo per-IP rate limiter (slice 466). Comma-separated CIDRs.
# DEFAULT OFF, shipped commented out: when unset (the bundle default), the
# server records the direct TCP peer address (r.RemoteAddr) as the client IP
# — byte-identical to today's behavior, no header is trusted.
#
# How it works: the server walks X-Forwarded-For RIGHT-TO-LEFT and accepts a
# hop only while the immediately-connecting peer is inside one of these
# CIDRs, stopping at the first untrusted hop (the real client). A client that
# is NOT behind one of these proxies cannot spoof its source IP by forging
# X-Forwarded-For, because its own connecting address is not in the allowlist.
#
# Set this to the address(es) your reverse proxy / load balancer / ingress
# connects FROM. Examples (TEST-NET ranges shown — replace with yours):
#   TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16
#   TRUSTED_PROXY_CIDRS=203.0.113.10/32
#
# SECURITY WARNING — only list CIDRs that are genuinely your own proxies.
# Listing 0.0.0.0/0 (or ::/0) trusts EVERY connecting address and reopens the
# client-IP spoofing vector — forged IPs would then land on every session row
# and on any IP-based rate-limit / audit decision. If you are NOT behind a
# proxy, leave this unset.
# TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16

# DEPRECATED (slice 465 → slice 466): boolean predecessor of
# TRUSTED_PROXY_CIDRS. When set to "1" AND TRUSTED_PROXY_CIDRS is unset, it
# is mapped to "trust any proxy" (0.0.0.0/0 + ::/0) for back-compat and the
# server logs a deprecation warning at boot. TRUSTED_PROXY_CIDRS always wins
# when both are set. Prefer TRUSTED_PROXY_CIDRS and remove this; trusting any
# proxy is a client-IP spoofing vector unless a header-scrubbing proxy is
# guaranteed in front. Any value other than "1" is treated as off.
# TRUST_FORWARDED_HEADERS=1

# ----- Email / SMTP notification channel (slice 445) -----
#
# The email delivery channel sends a daily digest of a user's UNREAD
# in-app notifications to their account email — IF that user has opted in
# (Settings -> Notifications -> Email delivery; default OFF). The email
# body carries summary counts + a deep-link back into the authenticated
# app only — never the notification details.
#
# DEFAULT OFF: when ATLAS_SMTP_HOST is unset (the bundle default), the
# channel is INERT — no mail is ever sent, no user can receive a digest
# regardless of their opt-in. Set the host + sender to enable it.
#
# Point these at YOUR SMTP relay (a transactional-email provider, your
# own postfix, or an internal relay). The channel sends only; it never
# receives mail. STARTTLS is used opportunistically when the server
# advertises it.
#
# SECURITY: ATLAS_SMTP_PASSWORD is read from the environment only and is
# NEVER written to logs or the delivery ledger. Generate/scope it per
# your provider. Use a dedicated, least-privilege send-only credential.
#
# ATLAS_SMTP_HOST=smtp.your-provider.example
# ATLAS_SMTP_PORT=587
# ATLAS_SMTP_SENDER=security-atlas@your-domain.example
# ATLAS_SMTP_USERNAME=CHANGE_ME
# ATLAS_SMTP_PASSWORD=CHANGE_ME
# ATLAS_SMTP_TIMEOUT=10s
#
# The public base URL used to build the digest deep-link back into the
# app. Set this to the URL your operators reach the web UI at, so the
# "Open your notifications" link in the email resolves. When unset, the
# link falls back to a relative /notifications path.
# ATLAS_PUBLIC_BASE_URL=https://atlas.your-domain.example

# ----- OpenTelemetry (slice 121) -----
#
# OTel SDK on/off switch. When this is unset (the default), atlas
# initializes its OTel SDK in NO-OP mode — no traces or metrics are
# exported, zero overhead. Set this to the OTel Collector OTLP endpoint
# to enable export. The companion `deploy/observability/` bundle ships
# the receive side (OTel Collector + Tempo + Prometheus). Other
# OTEL_* env-vars below follow the standard OpenTelemetry semantics;
# atlas adds none of its own. They are shipped commented (default off) and
# plumbed through docker-compose so uncommenting one here takes effect in
# the bundle. Leave them all commented for the no-op default.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# OTLP transport: `grpc` (default) or `http/protobuf`. Match your
# collector's receiver.
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Logical service name stamped on every span/metric. Defaults to the SDK's
# own default when unset.
# OTEL_SERVICE_NAME=security-atlas

# Extra resource attributes (comma-separated key=value pairs) merged onto
# every span/metric, e.g. `service.namespace=grc,service.version=1.2.3`.
# OTEL_RESOURCE_ATTRIBUTES=

# Trace sampler name + arg (standard OTel values, e.g.
# `parentbased_traceidratio` + `0.1`). Unset uses the SDK default.
# OTEL_TRACES_SAMPLER=
# OTEL_TRACES_SAMPLER_ARG=

# Free-form environment label that becomes the deployment.environment
# resource attribute on every emitted span/metric. Typical values:
# `homelab`, `staging`, `production`. Optional; when unset, the
# attribute is simply omitted from the resource.
# ATLAS_DEPLOYMENT_ENVIRONMENT=homelab

# Opt-in Prometheus `/metrics` fallback endpoint. When "true", atlas
# exposes a Prometheus-format scrape surface at GET /metrics, served
# unauthenticated (same auth-bypass pattern as /health and /v1/version).
# DEFAULT IS OFF (P0-A3 of slice 121): turning it on creates an
# unauthenticated read surface that MUST be gated at the network layer
# (firewall, reverse-proxy ACL, private subnet). Leave it off unless you
# specifically need a Prometheus pull path — the OTLP push path via
# OTEL_EXPORTER_OTLP_ENDPOINT above is the primary, safer default.
# ATLAS_METRICS_FALLBACK_ENABLE=false

# The API base URL the BROWSER uses to reach the atlas HTTP API. It must
# be reachable from the end user's machine.
#
# Leave EMPTY (the default) when this deployment is behind a reverse
# proxy that fronts both `web` and `atlas` under one hostname with
# path-based routing for /v1, /health, /api — the browser will use
# same-origin relative URLs and the proxy will route them to atlas.
#
# Set to an absolute URL only when the browser must reach atlas at a
# different origin than the web frontend (e.g. dev with web on :3000
# and atlas on :8080: NEXT_PUBLIC_API_BASE_URL=http://localhost:8080).
NEXT_PUBLIC_API_BASE_URL=

# ----- Test-mode (slice 201) -----
#
# When ATLAS_TEST_MODE=1 the atlas server mounts the Playwright e2e
# harness's JWT-issuance endpoint at POST /v1/test/issue-jwt. The
# endpoint accepts an arbitrary {tenant_id, user_id, roles, super_admin}
# body and returns a 1h JWT signed via the slice 187 OAuth keystore.
#
# DO NOT set this in a production deployment. It exposes the ability
# to mint admin-claim JWTs to any HTTP client that can reach the
# server. The default below (empty string) keeps production safe.
ATLAS_TEST_MODE=

# ----- Host port mappings (change only on port conflicts) -----
POSTGRES_PORT=5432
NATS_PORT=4222
NATS_MONITOR_PORT=8222
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
ATLAS_HTTP_PORT=8080
ATLAS_GRPC_PORT=50051
WEB_PORT=3000
