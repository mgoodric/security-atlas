{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.security-atlas.io/manual.attestation/1.1.0.json",
  "x-evidence-kind": "manual.attestation.v1",
  "x-semver": "1.1.0",
  "x-owner": "platform",
  "x-default-scf-anchors": ["GOV-04"],
  "title": "Manual attestation",
  "description": "A human attestation that a control state holds at a moment in time. v1.1 adds attestation_data, a free-form bag for control-specific fields that conform to the control bundle's manual_evidence_schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["attestor", "statement"],
  "properties": {
    "attestor": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 1 },
    "supporting_uri": { "type": "string", "format": "uri" },
    "attestation_data": { "type": "object" }
  }
}
