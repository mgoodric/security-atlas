{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.security-atlas.io/aws.s3.bucket_encryption_state/1.0.0.json",
  "x-evidence-kind": "aws.s3.bucket_encryption_state.v1",
  "x-semver": "1.0.0",
  "x-owner": "platform",
  "x-default-scf-anchors": ["CRY-04"],
  "title": "AWS S3 bucket encryption state",
  "description": "Per-bucket default-encryption configuration captured by the AWS connector.",
  "type": "object",
  "additionalProperties": false,
  "required": ["bucket_name", "encryption_enabled"],
  "properties": {
    "bucket_name": { "type": "string", "minLength": 1 },
    "encryption_enabled": { "type": "boolean" },
    "sse_algorithm": { "type": "string" },
    "kms_key_arn": { "type": "string" },
    "bucket_key_enabled": { "type": "boolean" },
    "account_id": { "type": "string" },
    "region": { "type": "string" }
  }
}
